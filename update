      {military && <div className="mt-3 rounded-xl border border-orange-400/15 bg-orange-500/5 p-2 text-[11px] text-zinc-300"><div>{military.nation} • {military.service}</div><div className="text-zinc-400">{military.role}, {military.mission}</div></div>}
    </button>
