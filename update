                    <div>
                      <div className="text-sm font-medium text-zinc-100">OSINT feeds</div>
                      <div className="text-xs text-zinc-400">{osintStatus.state === "connected" ? "Connected" : osintStatus.state === "loading" ? "Refreshing" : osintStatus.state === "degraded" ? "Partial data" : osintStatus.state === "error" ? "Error" : "Synthetic only"}</div>
                    </div>
                    <Switch checked={osintEnabled} onCheckedChange={setOsintEnabled} />
                  </div>
                  <div className="space-y-2 text-xs text-zinc-400">
                    {osintStatus.sources.length === 0 && <div>Uses proxy endpoint /api/osint/snapshot.</div>}
                    {osintStatus.sources.map((source) => (
                      <div key={source.source} className="flex items-center justify-between gap-3">
                        <span>{source.source}</span>
                        <span className={source.ok ? "text-emerald-200" : "text-orange-200"}>{source.ok ? `${source.count} tracks` : source.error || "unavailable"}</span>
                      </div>
                    ))}
                    {osintStatus.error && <div className="text-red-200">{osintStatus.error}</div>}
                  </div>
                </div>
                <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-3 text-xs text-zinc-300">
                  <div className="mb-2 font-medium text-zinc-100">Military posture</div>
                  <div>Total military tracks: <span className="text-zinc-100">{militarySummary.total}</span></div>
                  <div className="mt-2 flex flex-wrap gap-2">{militarySummary.nations.map((item) => <Badge key={item.name} className="border-orange-400/20 bg-orange-500/10 text-orange-200">{item.name}: {item.count}</Badge>)}</div>
                </div>
                {validationErrors.length > 0 && <div className="rounded-2xl border border-red-500/30 bg-red-500/10 p-3 text-xs text-red-100">{validationErrors.map((error) => <div key={error}>{error}</div>)}</div>}
              </CardContent>
            </Card>

            <Card className="rounded-[28px] border-zinc-800 bg-zinc-900/60">
              <CardHeader>
                <CardTitle className="flex items-center gap-2 text-lg"><Layers className="h-5 w-5 text-violet-300" /> Registry</CardTitle>
                <CardDescription className="text-zinc-400">All rendered tracks, filtered by the controls above.</CardDescription>
              </CardHeader>
              <CardContent>
                <ScrollArea className="h-[760px] pr-4"><div className="space-y-3">{filtered.map((track) => <RegistryRow key={track.id} track={track} selected={selectedLive} onSelect={selectTrack} />)}</div></ScrollArea>
              </CardContent>
            </Card>
          </div>

          <div className="space-y-6">
            <Card className="rounded-[28px] border-zinc-800 bg-zinc-900/60 shadow-2xl shadow-black/30">
              <CardHeader>
                <div className="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
                  <div>
                    <CardTitle className="flex items-center gap-3 text-2xl"><GlobeIcon className="h-6 w-6 text-cyan-300" /> Stable map</CardTitle>
                    <CardDescription className="mt-2 text-zinc-400">Dependency-light SVG world map with country outlines, deeper zoom, drag navigation, and a much smaller failure surface.</CardDescription>
                  </div>
                  <div className="flex flex-wrap gap-2">
                    <Badge className={`${liveMode ? "border-emerald-400/20 bg-emerald-500/10 text-emerald-200" : "border-zinc-700 bg-zinc-900 text-zinc-400"}`}>{liveStatus}</Badge>
                    <Button variant="outline" className="border-zinc-700 bg-zinc-950 text-zinc-100" onClick={() => setPlaying((value) => !value)}>{playing ? <Pause className="mr-2 h-4 w-4" /> : <Play className="mr-2 h-4 w-4" />}{playing ? "Pause" : "Play"}</Button>
                    <Button variant="outline" className="border-zinc-700 bg-zinc-950 text-zinc-100" onClick={resetAll}><RotateCcw className="mr-2 h-4 w-4" />Reset</Button>
                  </div>
                </div>
              </CardHeader>
              <CardContent>
                <GlobePanel tracks={filtered} selected={selectedLive} onSelect={selectTrack} regionKey={regionKey} setRegionKey={setRegionKey} ui={ui} setUi={setUi} stats={stats} history={history} goToRegion={goToRegion} selectCountry={setSelectedCountry} />
              </CardContent>
            </Card>

            <Card className="rounded-[28px] border-zinc-800 bg-zinc-900/60">
              <CardHeader>
                <CardTitle className="flex items-center gap-2 text-lg"><Layers className="h-5 w-5 text-cyan-300" /> Strategic briefing</CardTitle>
                <CardDescription className="text-zinc-400">The globe now flows directly into a readable brief instead of making you infer significance from icons alone.</CardDescription>
              </CardHeader>
              <CardContent className="space-y-4">
                <div className="flex flex-wrap gap-2">
                  <Button variant="outline" className="border-zinc-700 bg-zinc-950 text-zinc-100" onClick={() => setSelectedCountry(null)}>Latest updates</Button>
                  {Object.keys(COUNTRY_INTEL).map((country) => <button key={country} onClick={() => setSelectedCountry(country)} className={`rounded-full border px-3 py-1 text-xs ${selectedCountry === country ? "border-cyan-400/50 bg-zinc-900 text-zinc-100" : "border-zinc-800 bg-zinc-950 text-zinc-400"}`}>{country}</button>)}
                </div>
                {selectedCountryBrief ? (
                  <div className="grid gap-3 xl:grid-cols-[1.2fr_0.8fr]">
                    <div className="space-y-3">
                      <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">{selectedCountry}</div><div className="mt-2 text-sm text-zinc-200">{selectedCountryBrief.stance}</div></div>
                      <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">Why it matters</div><div className="mt-2 text-sm text-zinc-300">{selectedCountryBrief.significance}</div><div className="mt-3 text-xs text-zinc-400">{selectedCountryBrief.latest}</div><div className="mt-2 text-xs text-zinc-500">{selectedCountryBrief.whySignificant}</div></div>
                      <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">Key relations</div><div className="mt-3 grid gap-3 md:grid-cols-2">{selectedCountryBrief.relations.map((relation) => <div key={`${relation.country}-${relation.type}`} className="rounded-xl border border-zinc-800 bg-zinc-900 p-3"><div className="flex items-center justify-between gap-3"><div className="text-sm text-zinc-100">{relation.country}</div><Badge className="border-zinc-700 bg-zinc-950 text-zinc-100">{relation.type}</Badge></div><div className="mt-2 text-xs text-zinc-400">{relation.note}</div></div>)}</div></div>
                    </div>
                    <div className="space-y-3">
                      <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">Alliances</div><div className="mt-3 flex flex-wrap gap-2">{selectedCountryBrief.alliances.map((item) => <Badge key={item} className="border-cyan-400/20 bg-cyan-500/10 text-cyan-200">{item}</Badge>)}</div></div>
                      <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">Tensions</div><div className="mt-3 flex flex-wrap gap-2">{selectedCountryBrief.tensions.map((item) => <Badge key={item} className="border-orange-400/20 bg-orange-500/10 text-orange-200">{item}</Badge>)}</div></div>
                    </div>
                  </div>
                ) : (
                  <div className="grid gap-3 xl:grid-cols-2">{GLOBAL_BRIEFINGS.map((item) => <div key={item.id} className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-sm text-zinc-100">{item.title}</div><div className="mt-2 text-sm text-zinc-300">{item.summary}</div><div className="mt-2 text-xs text-zinc-400">Why significant: {item.significance}</div><div className="mt-3 flex flex-wrap gap-2">{item.tags.map((tag) => <button key={tag} onClick={() => COUNTRY_INTEL[tag] && setSelectedCountry(tag)} className={`rounded-full border px-3 py-1 text-xs ${COUNTRY_INTEL[tag] ? "border-zinc-700 bg-zinc-900 text-zinc-100" : "border-zinc-800 bg-zinc-950 text-zinc-500"}`}>{tag}</button>)}</div></div>)}</div>
                )}
              </CardContent>
            </Card>

            <Card className="rounded-[28px] border-zinc-800 bg-zinc-900/60">
              <CardHeader>
                <CardTitle className="flex items-center gap-2 text-lg"><Eye className="h-5 w-5 text-zinc-300" /> Event timeline</CardTitle>
                <CardDescription className="text-zinc-400">Use the globe for place, then this for sequence.</CardDescription>
              </CardHeader>
              <CardContent className="space-y-4">
                <div className="flex items-center justify-between"><div className="text-sm text-zinc-400">Closest event at current time marker</div><Badge className="border-zinc-700 bg-zinc-900 text-zinc-100">T+ {timeline[0]} min</Badge></div>
                <Slider value={timeline} onValueChange={setTimeline} min={0} max={100} step={1} />
                <div className="grid gap-3 md:grid-cols-4">{LIVE_EVENTS.map((event) => <button key={event.t} onClick={() => setTimeline([event.t])} className={`rounded-2xl border p-4 text-left ${timelineEvent.t === event.t ? "border-cyan-400/40 bg-zinc-900" : "border-zinc-800 bg-zinc-950"}`}><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">T+ {event.t}</div><div className="mt-1 font-medium text-zinc-100">{event.title}</div><div className="mt-2 text-xs text-zinc-400">{event.detail}</div></button>)}</div>
              </CardContent>
            </Card>
          </div>

          <div className="space-y-6">
            <Card className="rounded-[28px] border-zinc-800 bg-zinc-900/60">
              <CardHeader>
                <CardTitle className="flex items-center gap-2 text-lg"><LocateFixed className="h-5 w-5 text-cyan-300" /> Selected asset</CardTitle>
                <CardDescription className="text-zinc-400">Click any aircraft, vessel, or satellite for route, ownership, history, and inferred purpose.</CardDescription>
              </CardHeader>
              <CardContent className="space-y-4">
                <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4">
                  <div className="flex items-start justify-between gap-3">
                    <div>
                      <div className="font-semibold text-zinc-100">{selectedDossier?.id || "No selection"}</div>
                      <div className="text-xs text-zinc-400">{selectedDossier?.operator || "Pick a track from the globe or registry"}</div>
                    </div>
                    <div className="flex flex-wrap justify-end gap-2">
                      {selectedLive?.type && <Badge className={badgeTone(selectedLive.type, selectedLive.category)}>{selectedLive.category}</Badge>}
                      {selectedLive?.vesselClass && <Badge className={vesselClassTone(selectedLive.vesselClass)}>{selectedLive.vesselClass}</Badge>}
                    </div>
                  </div>
                  {selectedDossier && <div className="mt-3 grid grid-cols-2 gap-2 text-xs text-zinc-400">
                    <div className="rounded-xl border border-zinc-800 bg-zinc-900 p-3">Nation / flag<br /><span className="text-zinc-100">{selectedDossier.nation}</span></div>
                    <div className="rounded-xl border border-zinc-800 bg-zinc-900 p-3">Type<br /><span className="text-zinc-100">{selectedDossier.type}</span></div>
                    <div className="rounded-xl border border-zinc-800 bg-zinc-900 p-3">Heading<br /><span className="text-zinc-100">{selectedDossier.heading} deg</span></div>
                    <div className="rounded-xl border border-zinc-800 bg-zinc-900 p-3">Speed<br /><span className="text-zinc-100">{selectedDossier.speed || "--"}</span></div>
                  </div>}
                  <div className="mt-3 rounded-2xl border border-zinc-800 bg-zinc-900 p-3 text-xs text-zinc-300">
                    <div className="text-zinc-100">Route / flight path</div>
                    <div className="mt-1 text-zinc-400">{selectedDossier?.route || "No route available."}</div>
                    {selectedDossier?.historySummary && <div className="mt-2 text-zinc-500">{selectedDossier.historySummary}</div>}
                  </div>
                  <div className="mt-3 rounded-2xl border border-zinc-800 bg-zinc-900 p-3 text-xs text-zinc-300">
                    <div className="text-zinc-100">Why this matters</div>
                    <div className="mt-1 text-zinc-400">{selectedTrackSignificance}</div>
                    {linkedCountryFromAsset && COUNTRY_INTEL[linkedCountryFromAsset] && <Button variant="outline" className="mt-3 border-zinc-700 bg-zinc-950 text-zinc-100" onClick={() => setSelectedCountry(linkedCountryFromAsset)}>Open {linkedCountryFromAsset} brief</Button>}
                  </div>
                  {selectedDossier?.prediction && <div className="mt-3 rounded-2xl border border-cyan-400/20 bg-cyan-500/10 p-3 text-xs text-cyan-200">
                    <div className="text-zinc-100">Predicted purpose</div>
                    <div className="mt-1">{selectedDossier.prediction.purpose}</div>
                    <div className="mt-2 text-zinc-400">Confidence: {selectedDossier.prediction.confidence}</div>
                  </div>}
                </div>
                {selectedMilitary && <div className="rounded-2xl border border-orange-400/15 bg-orange-500/5 p-4 text-xs text-zinc-300"><div className="grid grid-cols-2 gap-3"><div>Nation<br /><span className="text-zinc-100">{selectedMilitary.nation}</span></div><div>Service<br /><span className="text-zinc-100">{selectedMilitary.service}</span></div><div>Role<br /><span className="text-zinc-100">{selectedMilitary.role}</span></div><div>Priority<br /><span className="text-zinc-100">{selectedMilitary.priority}</span></div></div><div className="mt-3">Mission<br /><span className="text-zinc-100">{selectedMilitary.mission}</span></div><div className="mt-3">Theater<br /><span className="text-zinc-100">{selectedMilitary.theater}</span></div></div>}
                <div className="grid grid-cols-2 gap-2 text-xs text-zinc-400"><div className="rounded-xl bg-zinc-950 p-3">Lat<br /><span className="text-zinc-200">{selectedLive?.lat?.toFixed(2) || "--"}</span></div><div className="rounded-xl bg-zinc-950 p-3">Lon<br /><span className="text-zinc-200">{selectedLive?.lon?.toFixed(2) || "--"}</span></div><div className="rounded-xl bg-zinc-950 p-3">Heading<br /><span className="text-zinc-200">{selectedLive ? `${Math.round(selectedLive.heading || 0)}°` : "--"}</span></div><div className="rounded-xl bg-zinc-950 p-3">Speed<br /><span className="text-zinc-200">{selectedLive ? Math.round(selectedLive.speed || 0) : "--"}</span></div></div>
                {selectedLive?.chokepoints?.length > 0 && <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">Linked chokepoints</div><div className="mt-3 flex flex-wrap gap-2">{selectedLive.chokepoints.map((name) => <Badge key={name} className="border-zinc-700 bg-zinc-900 text-zinc-100">{name}</Badge>)}</div></div>}
                {selectedLive?.chokepoints?.includes("Hormuz") && <div className="rounded-2xl border border-red-500/30 bg-red-500/10 p-4 text-xs text-red-100"><div className="font-medium text-zinc-100">Mine-claim overlay</div><div className="mt-2 text-zinc-300">This route intersects the Iran-claimed Hormuz mine-danger layer. Treat this as an unverified claim layer for routing awareness, not confirmed mine placement.</div></div>}
                {selectedDossier?.sources?.length > 0 && <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">OSINT source model</div><div className="mt-3 flex flex-wrap gap-2">{selectedDossier.sources.map((source) => <Badge key={source} className="border-zinc-700 bg-zinc-900 text-zinc-100">{source}</Badge>)}</div></div>}
              </CardContent>
            </Card>

            <Card className="rounded-[28px] border-zinc-800 bg-zinc-900/60">
              <CardHeader>
                <CardTitle className="flex items-center gap-2 text-lg"><Ship className="h-5 w-5 text-emerald-300" /> Strait traffic</CardTitle>
                <CardDescription className="text-zinc-400">All tagged traffic through chokepoints, regardless of country.</CardDescription>
              </CardHeader>
              <CardContent className="space-y-3">
                {chokepointTraffic.map((item) => (
                  <div key={item.name} className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4">
                    <div className="flex items-start justify-between gap-3">
                      <div><div className="font-medium text-zinc-100">{item.name}</div><div className="text-xs text-zinc-400">{item.note}</div></div>
                      <Badge className={item.severity === "high" ? "border-red-400/20 bg-red-500/10 text-red-200" : "border-zinc-700 bg-zinc-900 text-zinc-100"}>{item.tracks.length} tracks</Badge>
                    </div>
                    <div className="mt-3 grid grid-cols-3 gap-2 text-xs text-zinc-400">
                      <div>Vessels<br /><span className="text-zinc-100">{item.vessels.length}</span></div>
                      <div>Aircraft<br /><span className="text-zinc-100">{item.aircraft.length}</span></div>
                      <div>Military<br /><span className="text-zinc-100">{item.military.length}</span></div>
                    </div>
                    <div className="mt-3 flex flex-wrap gap-2">{item.vesselClasses.map((kind) => <Badge key={kind.name} className={vesselClassTone(kind.name)}>{kind.name}: {kind.count}</Badge>)}</div>
                    <div className="mt-3 space-y-2">{item.tracks.slice(0, 4).map((track) => <button key={track.id} onClick={() => selectTrack(track)} className="w-full rounded-xl border border-zinc-800 bg-zinc-900 p-2 text-left text-xs text-zinc-300"><span className="text-zinc-100">{track.id}</span> - {track.operator} - {track.type}</button>)}</div>
                  </div>
                ))}
              </CardContent>
            </Card>

            <Card className="rounded-[28px] border-zinc-800 bg-zinc-900/60">
              <CardHeader>
                <CardTitle className="flex items-center gap-2 text-lg"><Layers className="h-5 w-5 text-orange-300" /> Military brief</CardTitle>
                <CardDescription className="text-zinc-400">Nation, service, theater, and priority breakdown for the military picture.</CardDescription>
              </CardHeader>
              <CardContent className="space-y-4">
                <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">Top nations</div><div className="mt-3 space-y-2 text-sm text-zinc-300">{militarySummary.nations.map((item) => <div key={item.name} className="flex items-center justify-between"><span>{item.name}</span><span className="text-zinc-100">{item.count}</span></div>)}</div></div>
                <div className="grid gap-3 md:grid-cols-2"><div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">Services</div><div className="mt-3 space-y-2 text-sm text-zinc-300">{militarySummary.services.map((item) => <div key={item.name} className="flex items-center justify-between"><span>{item.name}</span><span className="text-zinc-100">{item.count}</span></div>)}</div></div><div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">Theaters</div><div className="mt-3 space-y-2 text-sm text-zinc-300">{militarySummary.theaters.map((item) => <div key={item.name} className="flex items-center justify-between"><span>{item.name}</span><span className="text-zinc-100">{item.count}</span></div>)}</div></div></div>
                <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="text-xs uppercase tracking-[0.16em] text-zinc-500">Priority bands</div><div className="mt-3 flex flex-wrap gap-2">{militarySummary.priorities.map((item) => <Badge key={item.name} className={item.name === "High" ? "border-red-400/20 bg-red-500/10 text-red-200" : item.name === "Elevated" ? "border-orange-400/20 bg-orange-500/10 text-orange-200" : "border-zinc-700 bg-zinc-900 text-zinc-100"}>{item.name}: {item.count}</Badge>)}</div></div>
              </CardContent>
            </Card>

            <Card className="rounded-[28px] border-zinc-800 bg-zinc-900/60">
              <CardHeader>
                <CardTitle className="flex items-center gap-2 text-lg"><Activity className="h-5 w-5 text-emerald-300" /> Live feed</CardTitle>
                <CardDescription className="text-zinc-400">Rolling updates generated from the moving world picture.</CardDescription>
              </CardHeader>
              <CardContent><div className="space-y-3">{liveFeed.map((entry) => <div key={entry.id} className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="flex items-start justify-between gap-3"><div><div className="font-medium text-zinc-100">{entry.title}</div><div className="text-xs text-zinc-400">{formatClock(entry.ts)}</div></div><Badge className={entry.level === "warning" ? "border-orange-400/20 bg-orange-500/10 text-orange-200" : "border-zinc-700 bg-zinc-900 text-zinc-100"}>{entry.level}</Badge></div><div className="mt-2 text-sm text-zinc-300">{entry.detail}</div></div>)}</div></CardContent>
            </Card>

            <Tabs defaultValue="alerts">
              <TabsList className="grid w-full grid-cols-2 bg-zinc-900/60"><TabsTrigger value="alerts">Alerts</TabsTrigger><TabsTrigger value="cameras">Cameras</TabsTrigger></TabsList>
              <TabsContent value="alerts"><Card className="rounded-[28px] border-zinc-800 bg-zinc-900/60"><CardContent className="space-y-3 p-6">{LIVE_EVENTS.map((event) => <div key={event.t} className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="flex items-start justify-between gap-3"><div><div className="font-medium text-zinc-100">{event.title}</div><div className="text-xs text-zinc-400">{event.region}</div></div><Badge className={event.severity === "high" ? "border-red-400/20 bg-red-500/10 text-red-200" : event.severity === "medium" ? "border-orange-400/20 bg-orange-500/10 text-orange-200" : "border-zinc-700 bg-zinc-900 text-zinc-100"}>{event.severity}</Badge></div><div className="mt-2 text-sm text-zinc-300">{event.detail}</div></div>)}</CardContent></Card></TabsContent>
              <TabsContent value="cameras"><Card className="rounded-[28px] border-zinc-800 bg-zinc-900/60"><CardContent className="space-y-3 p-6">{CAMERAS.map((camera) => <div key={camera.name} className="rounded-2xl border border-zinc-800 bg-zinc-950 p-4"><div className="flex items-start justify-between gap-3"><div><div className="font-medium text-zinc-100">{camera.name}</div><div className="text-xs text-zinc-400">{camera.city}</div></div><Camera className="h-4 w-4 text-zinc-400" /></div><div className="mt-3 rounded-xl border border-dashed border-zinc-700 bg-zinc-900/60 p-5 text-center text-xs text-zinc-500">{camera.note}</div></div>)}</CardContent></Card></TabsContent>
            </Tabs>
          </div>
        </div>
      </div>
    </div>
  );
}
