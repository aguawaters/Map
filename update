}

function GlobePanel({ tracks, selected, onSelect, regionKey, setRegionKey, ui, setUi, stats, history, goToRegion, selectCountry }) {
  const mapHostRef = useRef(null);
  const dragRef = useRef(null);
  const viewRef = useRef(null);
  const viewRafRef = useRef(null);
  const interactionTimerRef = useRef(null);
  const countryFeatures = useMemo(() => feature(countriesAtlas, countriesAtlas.objects.countries).features, []);
  const [view, setView] = useState(() => {
    const preset = REGION_PRESETS[regionKey] || REGION_PRESETS.global;
    return { lon: preset.lng, lat: preset.lat, scale: Math.round(260 / preset.altitude) };
  });
  const [mapMoving, setMapMoving] = useState(false);

  useEffect(() => {
    viewRef.current = view;
  }, [view]);

  const markMapMoving = () => {
    setMapMoving(true);
    if (interactionTimerRef.current) window.clearTimeout(interactionTimerRef.current);
    interactionTimerRef.current = window.setTimeout(() => setMapMoving(false), 180);
  };

  const applyView = (updater) => {
    const baseView = viewRef.current || view;
    const nextView = updater(baseView);
    viewRef.current = nextView;
    markMapMoving();
    if (viewRafRef.current) return;
    viewRafRef.current = window.requestAnimationFrame(() => {
      viewRafRef.current = null;
      setView(viewRef.current);
    });
  };

  useEffect(() => {
    const preset = REGION_PRESETS[regionKey] || REGION_PRESETS.global;
    const nextView = { lon: preset.lng, lat: preset.lat, scale: Math.round(260 / preset.altitude) };
    viewRef.current = nextView;
    setView(nextView);
  }, [regionKey]);

  useEffect(() => {
    const node = mapHostRef.current;
    if (!node) return undefined;
    const preventWheel = (event) => event.preventDefault();
    node.addEventListener("wheel", preventWheel, { passive: false });
    return () => node.removeEventListener("wheel", preventWheel);
  }, []);

  useEffect(() => () => {
    if (viewRafRef.current) window.cancelAnimationFrame(viewRafRef.current);
    if (interactionTimerRef.current) window.clearTimeout(interactionTimerRef.current);
  }, []);

  const projection = useMemo(() => geoOrthographic().translate([600, 340]).scale(view.scale).rotate([-view.lon, -view.lat]).clipAngle(90).precision(mapMoving ? 1.25 : 0.55), [mapMoving, view]);
  const path = useMemo(() => geoPath(projection), [projection]);
  const graticule = useMemo(() => geoGraticule10(), []);

  const isFront = (lon, lat) => hasLonLat({ lon, lat }) && geoDistance([lon, lat], [view.lon, view.lat]) <= Math.PI / 2;
  const zoomBy = (factor) => applyView((current) => ({ ...current, scale: clamp(current.scale * factor, 180, 2200) }));
  const focusSelectedOnMap = () => {
    if (!selected || !hasLonLat(selected)) return;
    const nextView = { lon: selected.lon, lat: selected.lat, scale: selected.type === "satellite" ? 900 : 1500 };
    viewRef.current = nextView;
    setView(nextView);
  };

  const onPointerDown = (event) => {
    event.currentTarget.setPointerCapture?.(event.pointerId);
    dragRef.current = { x: event.clientX, y: event.clientY, lon: view.lon, lat: view.lat };
    markMapMoving();
  };
  const onPointerMove = (event) => {
    if (!dragRef.current) return;
    const dx = event.clientX - dragRef.current.x;
    const dy = event.clientY - dragRef.current.y;
    const currentView = viewRef.current || view;
    const sensitivity = 120 / currentView.scale;
    applyView((current) => ({ ...current, lon: normalizeLon(dragRef.current.lon - dx * sensitivity), lat: clamp(dragRef.current.lat + dy * sensitivity, -80, 80) }));
  };
  const onPointerUp = (event) => {
    event.currentTarget.releasePointerCapture?.(event.pointerId);
    dragRef.current = null;
  };

  const safeTracks = useMemo(() => tracks.filter(hasLonLat), [tracks]);
  const visibleTracks = useMemo(() => safeTracks.filter((track) => isFront(track.lon, track.lat)), [safeTracks, view.lon, view.lat]);

  const airArcs = useMemo(() => ui.airTraffic && !mapMoving ? AIR_ROUTES.map((route, index) => {
    const from = AIRPORTS[route.from];
    const to = AIRPORTS[route.to];
    if (!from || !to || !hasLonLat(from) || !hasLonLat(to)) return null;
    return {
      id: `air-${index}`,
      category: route.category,
      d: path({ type: "LineString", coordinates: buildArcPoints({ lat: from.lat, lng: from.lon }, { lat: to.lat, lng: to.lon }).map((point) => [point.lng, point.lat]) }),
    };
  }).filter(Boolean) : [], [ui.airTraffic, mapMoving, path]);

  const seaArcs = useMemo(() => ui.maritimeTraffic && !mapMoving ? SEA_LANES.map((route, index) => {
    const from = PORTS[route.from];
    const to = PORTS[route.to];
    if (!from || !to || !hasLonLat(from) || !hasLonLat(to)) return null;
    return {
      id: `sea-${index}`,
      category: route.category,
      vesselClass: route.vesselClass || null,
      d: path({ type: "LineString", coordinates: buildArcPoints({ lat: from.lat, lng: from.lon }, { lat: to.lat, lng: to.lon }).map((point) => [point.lng, point.lat]) }),
    };
  }).filter(Boolean) : [], [ui.maritimeTraffic, mapMoving, path]);

  const projectedCountryLabels = useMemo(() => ui.labels && !mapMoving ? COUNTRY_LABELS.filter((item) => isFront(item.lon, item.lat)).map((item) => {
    const point = projection([item.lon, item.lat]);
    return point && Number.isFinite(point[0]) && Number.isFinite(point[1]) ? { ...item, x: point[0], y: point[1] } : null;
  }).filter(Boolean) : [], [ui.labels, mapMoving, projection, view.lon, view.lat]);

  const projectedCityLabels = useMemo(() => ui.labels && !mapMoving && view.scale > 360 ? CITY_LABELS.filter((item) => isFront(item.lon, item.lat)).map((item) => {
    const point = projection([item.lon, item.lat]);
    return point && Number.isFinite(point[0]) && Number.isFinite(point[1]) ? { ...item, x: point[0], y: point[1] } : null;
  }).filter(Boolean) : [], [ui.labels, mapMoving, projection, view.scale, view.lon, view.lat]);

  const projectedChokepoints = useMemo(() => ui.chokepoints && !mapMoving ? CHOKEPOINTS.filter((item) => isFront(item.centerLon, item.centerLat)).map((item) => {
    const point = projection([item.centerLon, item.centerLat]);
    return point && Number.isFinite(point[0]) && Number.isFinite(point[1]) ? { ...item, x: point[0], y: point[1] } : null;
  }).filter(Boolean) : [], [ui.chokepoints, mapMoving, projection, view.lon, view.lat]);

  const safePath = (obj) => {
    try {
      return path(obj) || "";
    } catch {
      return "";
    }
  };

  return (
    <div className="space-y-4">
      <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-3">
        <div className="mb-3 flex flex-wrap items-center justify-between gap-3">
          <div>
            <div className="text-sm font-semibold text-zinc-100">Areas</div>
            <div className="text-xs text-zinc-400">Preset theaters plus drag and deep zoom.</div>
          </div>
          <Badge className="border-zinc-700 bg-zinc-900 text-zinc-100">{REGION_PRESETS[regionKey].name}</Badge>
        </div>
        <Tabs value={regionKey} onValueChange={(key) => { setRegionKey(key); goToRegion(key); }}>
          <TabsList className="flex h-auto w-full flex-wrap justify-start gap-2 bg-zinc-950 p-1">
            {REGION_KEYS.map((key) => <TabsTrigger key={key} value={key} className="text-xs">{REGION_PRESETS[key].name}</TabsTrigger>)}
          </TabsList>
        </Tabs>
      </div>

      <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-3">
        <div className="mb-3 flex flex-wrap items-center justify-between gap-3">
          <div className="flex flex-wrap gap-2">
            <Badge className="border-cyan-400/20 bg-cyan-400/10 text-cyan-200">{stats.aircraft} aircraft</Badge>
            <Badge className="border-emerald-400/20 bg-emerald-400/10 text-emerald-200">{stats.vessels} vessels</Badge>
            <Badge className="border-emerald-400/20 bg-emerald-400/10 text-emerald-200">{stats.commercialVessels} commercial</Badge>
            <Badge className="border-orange-400/20 bg-orange-500/10 text-orange-200">{stats.militaryVessels} naval / military</Badge>
            <Badge className="border-violet-400/20 bg-violet-400/10 text-violet-200">{stats.satellites} satellites</Badge>
          </div>
          <div className="text-xs text-zinc-400">Scroll stays inside the map. Drag rotates. Zoom now goes much deeper.</div>
        </div>
        <div className="mb-3 flex flex-wrap gap-2 text-xs">
          <Badge className="border-cyan-400/20 bg-cyan-500/10 text-cyan-200"><Plane className="mr-2 h-4 w-4" /> Aircraft</Badge>
          <Badge className="border-emerald-400/20 bg-emerald-500/10 text-emerald-200"><Ship className="mr-2 h-4 w-4" /> Commercial vessels</Badge>
          <Badge className="border-rose-400/20 bg-rose-500/15 text-rose-200"><Ship className="mr-2 h-4 w-4" /> Military vessels</Badge>
          <Badge className="border-violet-400/20 bg-violet-500/15 text-violet-200"><Satellite className="mr-2 h-4 w-4" /> Satellites</Badge>
          <Badge className="border-red-400/20 bg-red-500/10 text-red-200">Claimed mine area</Badge>
        </div>

        <div ref={mapHostRef} className="overflow-hidden rounded-[24px] border border-zinc-800 bg-black" style={{ overscrollBehavior: "contain", touchAction: "none" }}>
          <svg
            viewBox="0 0 1200 680"
            className="h-[680px] w-full select-none"
            onPointerDown={onPointerDown}
            onPointerMove={onPointerMove}
            onPointerUp={onPointerUp}
            onPointerLeave={onPointerUp}
            onWheel={(event) => {
              event.preventDefault();
              zoomBy(event.deltaY < 0 ? 1.14 : 0.88);
            }}
