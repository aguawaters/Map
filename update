function buildLiveEntries(tracks, frame, selectedId) {
  const now = new Date();
  const entries = [];
  const safe = tracks.filter(hasLonLat);
  const selected = safe.find((track) => track.id === selectedId) || safe[0] || null;
  const eastAsiaTraffic = safe.filter((track) => track.lon > 115 && track.lon < 145 && track.lat > 20 && track.lat < 45);
  const gulfTraffic = safe.filter((track) => track.lon > 46 && track.lon < 60 && track.lat > 20 && track.lat < 30);
  const militaryVisible = safe.filter((track) => track.military).length;

  if (selected) {
    entries.push({
      id: `track-${Date.now()}-${frame}`,
      ts: now,
      level: selected.military ? "warning" : "info",
      title: `${selected.id} updated`,
      detail: `${selected.operator} ${selected.type} at ${selected.speed ? Math.round(selected.speed) : "--"}${selected.type === "aircraft" ? " kt" : selected.type === "vessel" ? " kn" : " km/h orbital"}.`,
    });
  }
  if (frame % 2 === 0) {
    entries.push({ id: `global-${Date.now()}-${frame}`, ts: now, level: "info", title: "Global traffic sweep", detail: `${safe.filter((track) => track.type === "aircraft").length} air tracks and ${safe.filter((track) => track.type === "vessel").length} maritime tracks active.` });
  }
  if (frame % 3 === 0) {
    entries.push({ id: `gulf-${Date.now()}-${frame}`, ts: now, level: gulfTraffic.length > 4 ? "warning" : "info", title: "Gulf watch", detail: `${gulfTraffic.length} tracked assets inside Gulf / Hormuz corridor.` });
  }
  if (frame % 4 === 0) {
    entries.push({ id: `eastasia-${Date.now()}-${frame}`, ts: now, level: eastAsiaTraffic.length > 10 ? "warning" : "info", title: "East Asia sweep", detail: `${eastAsiaTraffic.length} tracked assets across East Asia and NW Pacific corridors.` });
  }
  if (frame % 5 === 0) {
    entries.push({ id: `mil-${Date.now()}-${frame}`, ts: now, level: militaryVisible > 10 ? "warning" : "info", title: "Military picture", detail: `${militaryVisible} military-tagged tracks currently active.` });
  }
  return entries.slice(0, 5);
}

function stepTrack(track, frame) {
  if (!track || !hasLonLat(track)) return null;
  if (track.osint) return track;
  if (track.type === "satellite") {
    const nextPhase = track.phase + track.delta;
    return {
      ...track,
      phase: nextPhase,
      lat: Math.sin(nextPhase) * Math.min(track.inclination, 80),
      lon: normalizeLon(track.lonBase + nextPhase * track.drift * 22),
      heading: normalizeLon((track.heading || 0) + track.drift * 3),
    };
  }

  if (!Number.isFinite(track.progress)) return track;
  const nextProgress = (track.progress + track.delta) % 1;
  const points = buildArcPoints({ lat: track.fromLat, lng: track.fromLon }, { lat: track.toLat, lng: track.toLon });
  const pointIndex = Math.floor(nextProgress * (points.length - 1));
  const current = points[pointIndex] || points[0];
  const ahead = points[Math.min(points.length - 1, pointIndex + 1)] || current;
  if (!current || !ahead) return track;

  const heading = ((Math.atan2(ahead.lng - current.lng, ahead.lat - current.lat) * 180) / Math.PI + 360) % 360;
  return {
    ...track,
    progress: nextProgress,
    lon: current.lng,
    lat: current.lat,
    heading,
    altitude: track.type === "aircraft" ? clamp((track.altitude || 34000) + Math.sin(frame * 0.15 + nextProgress * 6) * 40, 25000, 43000) : 0,
    speed: track.type === "aircraft" ? clamp((track.speed || 450) + Math.sin(frame * 0.08 + nextProgress * 8), 360, 620) : clamp((track.speed || 18) + Math.sin(frame * 0.03 + nextProgress * 10) * 0.2, 8, 34),
  };
}

function pointColor(track) {
  if (track.type === "aircraft") return track.category === "military" ? "#fb923c" : "#67e8f9";
  if (track.type === "satellite") return track.category === "military" ? "#fb7185" : "#c4b5fd";
  return track.category === "military" ? "#fda4af" : track.vesselClass === "tanker" ? "#fb923c" : track.vesselClass === "lng" ? "#d946ef" : track.vesselClass === "bulk" ? "#f59e0b" : track.vesselClass === "ro-ro" ? "#10b981" : "#86efac";
}

function badgeTone(type, category) {
  if (type === "aircraft") return category === "military" ? "bg-orange-500/15 text-orange-200 border-orange-400/20" : "bg-cyan-500/15 text-cyan-200 border-cyan-400/20";
  if (type === "satellite") return category === "military" ? "bg-rose-500/15 text-rose-200 border-rose-400/20" : "bg-violet-500/15 text-violet-200 border-violet-400/20";
  return category === "military" ? "bg-pink-500/15 text-pink-200 border-pink-400/20" : "bg-emerald-500/15 text-emerald-200 border-emerald-400/20";
}

function vesselClassTone(vesselClass) {
  const tones = {
    container: "border-cyan-400/20 bg-cyan-500/10 text-cyan-200",
    tanker: "border-orange-400/20 bg-orange-500/10 text-orange-200",
    bulk: "border-amber-400/20 bg-amber-500/10 text-amber-200",
    lng: "border-fuchsia-400/20 bg-fuchsia-500/10 text-fuchsia-200",
    "ro-ro": "border-emerald-400/20 bg-emerald-500/10 text-emerald-200",
    naval: "border-rose-400/20 bg-rose-500/10 text-rose-200",
  };
  return tones[vesselClass] || "border-zinc-700 bg-zinc-900 text-zinc-100";
}

function getMilitaryProfile(track) {
  if (!track?.military) return null;
  const operator = (track.operator || "").toLowerCase();
  const endpoints = `${track.origin || ""} ${track.dest || ""}`.toLowerCase();

  let nation = "Unknown";
  let service = track.type === "vessel" ? "Navy" : track.type === "aircraft" ? "Air Force" : "Space / ISR";
  let role = track.type === "vessel" ? "Surface combatant" : track.type === "aircraft" ? "Patrol / transport" : "Recon / ISR";
  let mission = "Strategic watch";
  let priority = "Routine";

  if (operator.includes("us navy") || operator.includes("usaf") || operator.includes("us government")) nation = "United States";
  if (operator.includes("royal navy")) nation = "United Kingdom";
  if (operator.includes("russian")) nation = "Russia";
  if (operator.includes("indian")) nation = "India";
  if (operator.includes("pla") || operator === "plan") nation = "China";
  if (operator.includes("kpaf") || operator.includes("kpn")) nation = "North Korea";
  if (operator.includes("rocn")) nation = "Taiwan";

  if (track.type === "aircraft" && service === "Air Force") role = "Airlift / patrol";
  if (track.type === "vessel" && service === "Navy") role = nation === "United States" || nation === "United Kingdom" ? "Carrier / escort transit" : "Patrol / surface action";

  if (endpoints.includes("tpe") || endpoints.includes("tai")) {
    mission = "Taiwan Strait posture";
    priority = "High";
  } else if (endpoints.includes("fnj") || endpoints.includes("wsn") || endpoints.includes("nam") || endpoints.includes("cho") || endpoints.includes("ras")) {
    mission = "Korean Peninsula watch";
    priority = "High";
  } else if (endpoints.includes("dov") || endpoints.includes("rms") || endpoints.includes("gib") || endpoints.includes("sue")) {
    mission = "Atlantic / Med transit";
    priority = "Elevated";
  } else if (endpoints.includes("viz") || endpoints.includes("and") || endpoints.includes("chn") || endpoints.includes("koc")) {
    mission = "Indian Ocean posture";
    priority = "Elevated";
  }

  let theater = "Global";
  if (hasLonLat(track)) {
    if (track.lon > 115 && track.lon < 145 && track.lat > 20 && track.lat < 50) theater = "East Asia / NW Pacific";
    else if (track.lon > 65 && track.lon < 95 && track.lat > 5 && track.lat < 30) theater = "South Asia / Indian Ocean";
    else if (track.lon > 46 && track.lon < 60 && track.lat > 20 && track.lat < 30) theater = "Gulf / Arabian Sea";
    else if (track.lon > -10 && track.lon < 40 && track.lat > 30 && track.lat < 60) theater = "Europe / East Med";
    else if (track.lon < -20 && track.lon > -90 && track.lat > 20 && track.lat < 55) theater = "North Atlantic";
  }

  return { nation, service, role, mission, theater, priority };
}

function summarizeMilitary(tracks) {
  const profiled = tracks.filter((track) => track?.military).map((track) => ({ profile: getMilitaryProfile(track) })).filter((item) => item.profile);
  const countBy = (key) => Object.entries(profiled.reduce((acc, item) => {
    const value = item.profile[key];
    acc[value] = (acc[value] || 0) + 1;
    return acc;
  }, {})).map(([name, count]) => ({ name, count })).sort((a, b) => b.count - a.count);
  return {
    total: profiled.length,
    nations: countBy("nation").slice(0, 6),
    services: countBy("service").slice(0, 4),
    theaters: countBy("theater").slice(0, 4),
    priorities: countBy("priority").slice(0, 3),
  };
}

function getCountryFromTrack(track) {
  if (!track) return null;
  const military = getMilitaryProfile(track);
  if (military?.nation && COUNTRY_INTEL[military.nation]) return military.nation;
  if (track.type === "aircraft") {
    const from = AIRPORTS[track.origin]?.country;
    const to = AIRPORTS[track.dest]?.country;
    return COUNTRY_INTEL[from] ? from : COUNTRY_INTEL[to] ? to : null;
  }
  if (track.type === "vessel") {
    const from = PORTS[track.origin]?.country;
    const to = PORTS[track.dest]?.country;
    return COUNTRY_INTEL[from] ? from : COUNTRY_INTEL[to] ? to : null;
  }
  return null;
}

function getTrackSignificance(track) {
  if (!track) return "No asset selected.";
  const military = getMilitaryProfile(track);
  if (military) {
    return `${military.nation} ${military.service.toLowerCase()} ${track.type} linked to ${military.mission.toLowerCase()} in ${military.theater}. Priority is ${military.priority.toLowerCase()} because the route touches a live strategic corridor.`;
  }
  if (track.type === "vessel") {
    const vesselClass = track.vesselClass ? `${track.vesselClass} vessel` : "commercial vessel";
    const chokepointText = track.chokepoints?.length ? ` It touches ${track.chokepoints.join(", ")}, which makes it more strategically sensitive.` : "";
    return `${vesselClass[0].toUpperCase()}${vesselClass.slice(1)} moving between ${PORTS[track.origin]?.city || track.origin} and ${PORTS[track.dest]?.city || track.dest}. This matters because shipping lanes are where regional conflict turns into price and supply shocks.${chokepointText}`;
  }
  if (track.type === "aircraft") {
    return `Commercial air traffic between ${AIRPORTS[track.origin]?.city || track.origin} and ${AIRPORTS[track.dest]?.city || track.dest}. This matters because air routing bends quickly when conflict, airspace restrictions, or alliance strain intensify.`;
  }
  return "Orbital asset shaping the wider awareness picture rather than a country-to-country route.";
}

function getEndpoint(track, side) {
  if (!track) return null;
  const code = side === "origin" ? track.origin : track.dest;
  if (!code) return null;
  const source = track.type === "aircraft" ? AIRPORTS : PORTS;
  return source[code] ? { ...source[code], code } : { code, city: code, country: "Unknown", lon: null, lat: null };
}

function routeLabel(track) {
  const origin = getEndpoint(track, "origin");
  const dest = getEndpoint(track, "dest");
  if (!origin || !dest) return track?.type === "satellite" ? "Orbital ground track" : "Unknown route";
  return `${origin.city} (${origin.code}) to ${dest.city} (${dest.code})`;
}

function getAssetNation(track) {
  if (!track) return "Unknown";
  const military = getMilitaryProfile(track);
  if (military?.nation && military.nation !== "Unknown") return military.nation;
  const origin = getEndpoint(track, "origin");
  const dest = getEndpoint(track, "dest");
  if (track.type === "satellite") {
    if ((track.operator || "").includes("SpaceX")) return "United States";
    if ((track.operator || "").includes("OneWeb")) return "United Kingdom";
    if ((track.operator || "").includes("ISS")) return "Multinational";
    if ((track.operator || "").includes("US Government")) return "United States";
    return "Commercial / multinational";
  }
  return origin?.country || dest?.country || "Unknown";
}

function getOsintSourcesForTrack(track) {
  if (!track) return [];
  if (track.osint?.source) return [track.osint.source, track.osint.confidence || "Provider-normalized observation", ...getOsintSourcesForTrack({ ...track, osint: null })];
  if (track.type === "aircraft") return ["ADS-B / Mode-S feeds", "OpenSky-style state vectors", "airport/airline schedules", "NOTAM and airspace advisories"];
  if (track.type === "vessel") return ["AIS terrestrial/satellite feeds", "port call records", "vessel registry and flag databases", "maritime advisories and chokepoint reports"];
  return ["CelesTrak / Space-Track TLE catalogs", "operator constellation filings", "public orbital element sets", "ground-track prediction"];
}

function getPredictedPurpose(track) {
  if (!track) return { purpose: "No track selected.", confidence: "Low" };
  const military = getMilitaryProfile(track);
  if (military) {
    return {
      purpose: `${military.mission}. The route, operator, and service profile suggest ${military.role.toLowerCase()} activity in ${military.theater}.`,
      confidence: military.priority === "High" ? "Medium-high" : "Medium",
    };
  }
  if (track.type === "vessel") {
    const classPurpose = {
      container: "containerized cargo movement across scheduled commercial lanes",
      tanker: "liquid energy or refined product transport with energy-market sensitivity",
      lng: "LNG movement, likely tied to power generation and energy supply contracts",
      bulk: "dry bulk commodity transport such as grain, ore, or industrial inputs",
      "ro-ro": "vehicle or rolling-equipment transport",
    };
    const chokepointText = track.chokepoints?.length ? ` It is strategically relevant because it intersects ${track.chokepoints.join(", ")}.` : "";
    return { purpose: `${classPurpose[track.vesselClass] || "commercial maritime movement"}.${chokepointText}`, confidence: "Medium" };
  }
  if (track.type === "aircraft") {
    const origin = getEndpoint(track, "origin");
    const dest = getEndpoint(track, "dest");
    return {
      purpose: `Commercial passenger/cargo movement on the ${origin?.city || track.origin} to ${dest?.city || track.dest} corridor. Routing sensitivity rises near restricted airspace or conflict zones.`,
      confidence: "Medium",
    };
  }
  return {
    purpose: `${track.operator} orbital coverage pass. Likely communications, Earth observation, or ISR support depending on operator category.`,
    confidence: track.category === "military" ? "Medium" : "Low-medium",
  };
}

function getTrackHistory(track, history) {
  const points = history?.[track?.id] || [];
  if (!track || points.length === 0) return "No recent trail points captured yet.";
  const first = points[0];
  const last = points[points.length - 1];
  if (!Array.isArray(first) || !Array.isArray(last)) return "Recent trail is unavailable.";
  return `${points.length} recent positions from ${first[1].toFixed(2)}, ${first[0].toFixed(2)} to ${last[1].toFixed(2)}, ${last[0].toFixed(2)}.`;
}

function getAssetDossier(track, history) {
  if (!track) return null;
  const origin = getEndpoint(track, "origin");
  const dest = getEndpoint(track, "dest");
  const military = getMilitaryProfile(track);
  const prediction = getPredictedPurpose(track);
  return {
    id: track.id,
    type: track.type,
    category: track.category,
    operator: track.operator || "Unknown operator",
    nation: getAssetNation(track),
    route: routeLabel(track),
    origin,
    dest,
    military,
    prediction,
    historySummary: getTrackHistory(track, history),
    speed: track.speed ? Math.round(track.speed) : null,
    altitude: track.type === "aircraft" ? Math.round(track.altitude || 0) : track.type === "satellite" ? Math.round(track.altitude || 0) : null,
    heading: Math.round(track.heading || 0),
    chokepoints: track.chokepoints || [],
    vesselClass: track.vesselClass,
    sources: getOsintSourcesForTrack(track),
  };
}

function summarizeChokepointTraffic(tracks) {
  return CHOKEPOINTS.map((chokepoint) => {
    const matches = tracks.filter((track) => track.chokepoints?.includes(chokepoint.name));
    const vessels = matches.filter((track) => track.type === "vessel");
    const aircraft = matches.filter((track) => track.type === "aircraft");
    const military = matches.filter((track) => track.military);
    const vesselClasses = VESSEL_CLASS_OPTIONS.filter((name) => name !== "all").map((name) => ({
      name,
      count: vessels.filter((track) => track.vesselClass === name).length,
    })).filter((item) => item.count > 0);

    return {
      ...chokepoint,
      tracks: matches,
      vessels,
      aircraft,
      military,
      vesselClasses,
    };
  });
}

function enrichOsintTracks(tracks) {
  return tracks.map((track) => ({
    ...track,
    chokepoints: track.chokepoints?.length ? track.chokepoints : routeChokepointsForPoints([{ lng: track.lon, lat: track.lat }]),
  }));
}

function TrackIcon({ type }) {
  if (type === "aircraft") return <Plane className="h-4 w-4" />;
  if (type === "satellite") return <Satellite className="h-4 w-4" />;
  return <Ship className="h-4 w-4" />;
}

